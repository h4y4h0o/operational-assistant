# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter .env dans le repo

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opsdb
POSTGRES_USER=opsadmin
POSTGRES_PASSWORD=CHANGE_ME

# API
API_BEARER_TOKEN=CHANGE_ME
API_PORT=8000

# LLM (choisir un provider)
LLM_PROVIDER=claude          # ou "openai"
LLM_API_KEY=CHANGE_ME
LLM_MODEL=claude-sonnet-4-6  # ou "gpt-4o"

# Slack (géré dans n8n credentials, pas ici)
# SLACK_BOT_TOKEN=xoxb-...
